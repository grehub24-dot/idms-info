{
  "functions": {
    "api/**/*.php": { "runtime": "vercel-php@0.6.0" }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/router.php?path=$1"
    },
    {
      "src": "/admin/(.*)$",
      "dest": "/api/admin.php?path=$1"
    },
    {
      "src": "/student/(.*)$",
      "dest": "/api/student.php?path=$1"
    }
  ]
}
